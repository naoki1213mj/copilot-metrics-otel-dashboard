# GitHub API
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_ORG=your-org-name

# Azure の環境名とリージョンは azd env が管理する
# AZURE_ENV_NAME=copilot-otel-eus2
# AZURE_LOCATION=eastus2

# 取得対象の日数（1〜100）
COPILOT_METRICS_DAYS=100

# データソース（github / mock）
COPILOT_METRICS_SOURCE=mock

# Azure Functions timer trigger（UTC の NCRONTAB）
INGESTION_TIMER_SCHEDULE="0 15 2 * * *"

# Azure Functions から Blob Storage / Cosmos DB へ保存する時の接続先
# ローカルでは connection string、Azure では managed identity + endpoint を使う
# AzureWebJobsStorage=DefaultEndpointsProtocol=https;AccountName=...
# COPILOT_METRICS_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# METRICS_STORAGE_BLOB_ENDPOINT=https://<storage-account-name>.blob.core.windows.net
# COSMOSDB_CONNECTION_STRING=AccountEndpoint=https://...:443/;AccountKey=...
# AZURE_COSMOS_ENDPOINT=https://<cosmos-account-name>.documents.azure.com:443/
# Azure Functions host storage は AzureWebJobsStorage__accountName / __credential /
# __blobServiceUri / __queueServiceUri / __tableServiceUri を app settings で構成する
METRICS_RAW_CONTAINER=raw-metrics
METRICS_CURATED_CONTAINER=curated-metrics
METRICS_DASHBOARD_CONTAINER=dashboard-data

# Cosmos DB に run metadata / persisted history を保存する
AZURE_COSMOS_DATABASE_NAME=copilotMetrics
AZURE_COSMOS_METRICS_CONTAINER_NAME=usageMetrics
AZURE_COSMOS_INGESTION_RUNS_CONTAINER_NAME=ingestionRuns
AZURE_COSMOS_DASHBOARD_VIEWS_CONTAINER_NAME=dashboardViews

# Function App でも既存のローカル出力を残したい場合だけ true
INGESTION_WRITE_LOCAL_OUTPUTS=false

# mock ソース時の再現用シード
INGESTION_MOCK_SEED=42

# Application Insights（省略可。設定すると OTel トレースが有効になる）
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...
